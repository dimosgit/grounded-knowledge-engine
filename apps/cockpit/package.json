{
  "name": "cockpit",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "sync:content": "tsx scripts/sync-markdown.ts",
    "watch:content": "tsx scripts/watch-markdown.ts",
    "dev": "concurrently -k \"npm run watch:content\" \"vite\"",
    "prebuild": "npm run sync:content",
    "build": "vite build",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.scripts.json",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretest": "npm run sync:content"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^12.35.2",
    "lucide-react": "^0.577.0",
    "mermaid": "^11.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^5.4.10",
    "vitest": "^4.0.18"
  }
}
