{
  "name": "grounded-knowledge-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "gke": "./dist/tools/cli.js"
  },
  "engines": {
    "node": ">=22.5"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json",
    "setup:mcp": "node scripts/configure-mcp.mjs",
    "setup:claude": "node scripts/configure-claude.mjs",
    "dev:mcp": "tsx tools/kb-mcp-server/server.ts",
    "dev:mcp:http": "tsx tools/kb-mcp-server/server-http.ts",
    "search": "tsx tools/grounding/local-grounding-search.ts",
    "eval": "tsx tools/grounding/evaluate-retrieval.ts",
    "eval:workspace": "tsx tools/grounding/evaluate-retrieval.ts --file tools/grounding/eval/workspace-shapes.json --repo-root tools/grounding/eval/workspace-fixtures --scan-root kb --refresh --deterministic",
    "test:evaluator": "tsx tools/grounding/evaluate-retrieval-test.ts",
    "test:retrieval": "npm run test:evaluator && npm run eval:workspace -- --backend bm25 && npm run eval:workspace -- --backend sqlite",
    "smoke:mcp": "tsx tools/kb-mcp-server/smoke-test.ts",
    "test:mcp:catalog": "tsx tools/kb-mcp-server/schema-budget-test.ts",
    "test:mcp:transport": "tsx tools/kb-mcp-server/transport-test.ts",
    "test:mcp:http": "tsx tools/kb-mcp-server/http-integration-test.ts",
    "test:loop": "tsx tools/kb-mcp-server/loop-integration-test.ts",
    "test:projects": "tsx tools/projects/project-context-test.ts",
    "test:project-service": "tsx tools/projects/project-service-test.ts",
    "test:project-review": "tsx tools/projects/project-review-test.ts",
    "test:document-core": "tsx tools/grounding/document-core-test.ts",
    "test:answer-service": "tsx tools/grounding/answer-service-test.ts",
    "test:capture": "tsx tools/capture/capture-service-test.ts && tsx tools/capture/capture-routing-test.ts && tsx tools/capture/grounded-capture-service-test.ts && tsx tools/capture/ask-capture-loop-test.ts",
    "demo:project": "tsx tools/projects/demo-resume.ts",
    "test:ingest:unit": "tsx tools/ingest/unit-test.ts",
    "test:ingest": "tsx tools/ingest/ingest-integration-test.ts",
    "test:gke": "npm run test:mcp:catalog && npm run test:mcp:transport && npm run test:projects && npm run test:project-service && npm run test:project-review && npm run test:document-core && npm run test:answer-service && npm run test:capture && npm run smoke:mcp && npm run test:loop && npm run test:ingest:unit && npm run test:ingest && npm run test:retrieval",
    "project": "tsx tools/projects/cli.ts",
    "export:demo-projects": "tsx tools/projects/export-demo.ts",
    "ingest": "tsx tools/ingest/ingest.ts",
    "ingest:fixtures": "tsx tools/ingest/fixtures/make-fixtures.ts",
    "scrub": "bash scripts/scrub-gate.sh",
    "lint": "eslint tools",
    "format": "prettier --write \"tools/**/*.ts\" \"scripts/**/*.{ts,mjs}\" \"*.{ts,json,md}\"",
    "format:check": "prettier --check \"tools/**/*.ts\" \"scripts/**/*.{ts,mjs}\" \"*.{ts,json,md}\""
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "mammoth": "^1.12.0",
    "unpdf": "^1.6.2"
  },
  "overrides": {
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.9.3",
    "@types/pdfkit": "^0.17.6",
    "docx": "^9.7.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "globals": "^15.15.0",
    "pdfkit": "^0.19.1",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  }
}
